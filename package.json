{
  "name": "pi-extensions",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "description": "Monorepo for Pi extensions.",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "extensions/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohammedhammoud/pi-extensions.git"
  },
  "scripts": {
    "clean": "pnpm --recursive run clean",
    "build": "pnpm --recursive run build",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run knip",
    "typecheck": "pnpm --recursive run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "knip:fix": "knip --fix --format",
    "commitlint": "commitlint",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "pack:all": "pnpm -r --filter '!.' exec pnpm pack",
    "publish:all": "pnpm publish -r --access public --no-git-checks"
  },
  "lint-staged": {
    "*.{ts,js,cjs,json,md}": [
      "prettier --write"
    ],
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "@eslint/js": "^9.26.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.4",
    "prettier": "^3.6.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  }
}
