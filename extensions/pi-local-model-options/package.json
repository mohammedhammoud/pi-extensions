{
  "name": "@mohammedhammoud/pi-local-model-options",
  "version": "0.2.1",
  "description": "Pi extension for per-model local model options.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "local-llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammedhammoud/pi-extensions",
    "directory": "extensions/pi-local-model-options"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsdown",
    "check": "pnpm run typecheck",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.0",
    "@earendil-works/pi-tui": "^0.75.0"
  }
}
